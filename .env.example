# Environment Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=ecommerce_chatbot

# OpenAI API Key (optional - for GPT fallback)
OPENAI_API_KEY=

# Google Gemini API Key (optional - for multilingual support)
GEMINI_API_KEY=

# Google Custom Search API (for auto product images)
GOOGLE_CSE_KEY=
GOOGLE_CSE_CX=

# SMTP Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM_NAME=AI-Powered E-commerce Support

# Brevo API Key (alternative email provider)
BREVO_API_KEY=

# Site Configuration
SITE_NAME=AI-Powered Chatbot For E-commerce Support
SITE_URL=http://localhost/ecommerce-chatbot
CURRENCY=RWF
CURRENCY_SYMBOL=RWF 

# Admin Contact
ADMIN_EMAIL=ericniringiyimana123@gmail.com
ADMIN_NAME=Eric Niringiyimana
ADMIN_PHONE=+250782977559

# Security Settings
CSRF_EXPIRE=3600
SESSION_LIFETIME=86400
MAX_LOGIN_ATTEMPTS=5
RATE_LIMIT_CHAT=20
RATE_LIMIT_SEARCH=30

# ML API Configuration
ML_API_URL=http://localhost:5000
ML_API_TIMEOUT=5

# Redis Configuration (optional - for caching)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Error Logging
LOG_ERRORS=true
LOG_FILE=c:/xampp/htdocs/ecommerce-chatbot/logs/error.log
LOG_LEVEL=error
